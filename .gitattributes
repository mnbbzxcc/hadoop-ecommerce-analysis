# 所有文本文件默认使用 LF（适配 Linux 部署）
* text=auto eol=lf

# Java 生态
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# 脚本（LF 否则在 Linux 上会报错）
*.sh text eol=lf
*.py text eol=lf

# 前端
*.js text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.json text eol=lf
*.svg text eol=lf

# 文档 / 配置
*.md text eol=lf
*.sql text eol=lf
*.conf text eol=lf
*.env text eol=lf
Dockerfile text eol=lf

# Windows 批处理（必须 CRLF 才能运行）
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件不做任何转换
*.jar binary
*.war binary
*.class binary
*.png binary
*.jpg binary
*.ico binary
