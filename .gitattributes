# 自动检测文本文件并规范化换行符
* text=auto

# Java 源代码使用 LF
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# 脚本使用 LF（否则在 Linux 上会报错）
*.sh text eol=lf
*.py text eol=lf

# Windows 批处理使用 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件不做任何转换
*.jar binary
*.war binary
*.class binary
*.png binary
*.jpg binary